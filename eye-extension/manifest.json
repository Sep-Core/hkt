{
  "manifest_version": 3,
  "name": "Shrimp Gaze Debug Tool",
  "version": "0.2.0",
  "description": "Fetch gaze coordinates from local API and render spotlight/debug overlay.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Python Gaze Demo"
  }
}
